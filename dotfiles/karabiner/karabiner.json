{
    "profiles": [
        {
            "name": "Default profile",
            "selected": true,
            "simple_modifications": [
                {
                    "from": { "key_code": "right_command" },
                    "to": [{ "key_code": "right_control" }]
                }
            ],
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Chrome: Command+J/K for tab navigation",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "j",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "to": [{ "key_code": "page_up", "modifiers": ["control"] }],
                                "conditions": [
                                    {
                                        "type": "frontmost_application_if",
                                        "bundle_identifiers": ["^com\\.google\\.Chrome$"]
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "k",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "to": [{ "key_code": "page_down", "modifiers": ["control"] }],
                                "conditions": [
                                    {
                                        "type": "frontmost_application_if",
                                        "bundle_identifiers": ["^com\\.google\\.Chrome$"]
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "i",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "to": [{ "key_code": "up_arrow" }],
                                "conditions": [
                                    {
                                        "type": "frontmost_application_if",
                                        "bundle_identifiers": ["^com\\.google\\.Chrome$"]
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "m",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "to": [{ "key_code": "down_arrow" }],
                                "conditions": [
                                    {
                                        "type": "frontmost_application_if",
                                        "bundle_identifiers": ["^com\\.google\\.Chrome$"]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "description": "Left keys: swap Command/Control, Escape in Neovim",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": { "key_code": "left_control" },
                                "to": [{ "key_code": "left_command" }],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "conditions": [
                                    {
                                        "type": "variable_if",
                                        "name": "neovim_mode",
                                        "value": 1
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "left_control" },
                                "to": [{ "key_code": "left_command" }],
                                "conditions": [
                                    {
                                        "type": "variable_unless",
                                        "name": "neovim_mode",
                                        "value": 1
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "left_command" },
                                "to": [{ "key_code": "left_control" }]
                            }
                        ]
                    }
                ]
            },
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}
